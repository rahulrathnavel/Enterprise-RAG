# NVIDIA NIM/OpenAI-compatible endpoint for chat and embedding models.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model-specific API keys. Public deployments must set these as environment
# variables in the hosting dashboard. Do not commit real values to GitHub.
NVIDIA_QWEN_API_KEY=
NVIDIA_MISTRAL_API_KEY=
NVIDIA_EMBED_API_KEY=
NVIDIA_EMBEDCODE_API_KEY=
NVIDIA_RERANK_API_KEY=
NVIDIA_SAFETY_API_KEY=
GLINER_PII_API_KEY=

# Model identifiers used by NVIDIA NIM.
NVIDIA_QWEN_MODEL=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_MISTRAL_MODEL=mistralai/mistral-large-3-675b-instruct-2512
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1
NVIDIA_EMBEDCODE_MODEL=nvidia/nv-embedcode-7b-v1
NVIDIA_SAFETY_MODEL=nvidia/nemotron-content-safety-reasoning-4b

# The hosted reranking API has a retrieval-specific URL and model name.
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
NVIDIA_RERANK_MODEL=nv-rerank-qa-mistral-4b:1

# Local storage paths.
APP_ENV=production
ALLOW_LOCAL_SECRET_FILE=false
TENANT_ID=demo_enterprise
SQLITE_DB_PATH=data/generated/enterprise_demo.db
QDRANT_PATH=data/qdrant
QDRANT_TEXT_COLLECTION=enterprise_text
QDRANT_CODE_COLLECTION=enterprise_code_logs

# Production behavior. Keep local fallback disabled when you want the public app
# to use the exact NVIDIA NIM models instead of deterministic local fallbacks.
ENABLE_LOCAL_MODEL_FALLBACK=false
FORCE_LOCAL_MODEL_FALLBACK=false
ENABLE_REMOTE_SAFETY=false
BUILD_INDEX_ON_STARTUP=true
MAX_SQL_ROWS=100
MAX_RETRIEVAL_RESULTS=8
RERANK_TOP_N=5
